+            // (resisted by Rock/Steel, immune vs Ghost). The MOVES map is built
+            // per-compiled-gen (choices.rs is shared but each binary sets exactly
+            // one gen feature), so this compile-time gate keeps gen1 correct while
+            // making gen3 — the only gen this crate builds — typeless. The gen3
+            // type chart maps TYPELESS -> 1.0 vs all and stab_modifier returns 1.0
+            // for TYPELESS (see src/gen3/damage_calc.rs), so no downstream change
+            // is needed. Mirrors how gen3 Curse is TYPELESS.
+            move_type: if cfg!(feature = "gen1") {
+                PokemonType::NORMAL
+            } else {
+                PokemonType::TYPELESS
+            },
