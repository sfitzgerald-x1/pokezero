@@ -9,6 +10,20 @@ import logging
 logger = logging.getLogger(__name__)
 
 
+def _capture(direction, message):
+    # Teacher-capture hook for pokezero behavior cloning. Inert unless FOULPLAY_CAPTURE_PATH is
+    # set; when set, append each received protocol block and each outgoing /choose as a JSONL
+    # line. Kept transport-level so it is independent of foul-play's internal battle state.
+    path = os.environ.get("FOULPLAY_CAPTURE_PATH")
+    if not path:
+        return
+    try:
+        with open(path, "a") as handle:
+            handle.write(json.dumps({"t": direction, "msg": message}) + "\n")
+    except OSError:
+        pass
+
