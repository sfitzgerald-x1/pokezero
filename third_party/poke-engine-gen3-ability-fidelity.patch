+fn add_end_of_turn_branches(
+    state: &mut State,
+    instructions: &mut Vec<StateInstructions>,
+    first_move_side: &SideReference,
+) {
+    let incoming = std::mem::take(instructions);
+    for base in incoming {
+        state.apply_instructions(&base.instruction_list);
+        let eligible = [
+            {
+                let mon = state.side_one.get_active_immutable();
+                mon.hp > 0
+                    && mon.ability == Abilities::SHEDSKIN
+                    && mon.status != PokemonStatus::NONE
+            },
+            {
+                let mon = state.side_two.get_active_immutable();
+                mon.hp > 0
+                    && mon.ability == Abilities::SHEDSKIN
+                    && mon.status != PokemonStatus::NONE
+            },
+        ];
+        state.reverse_instructions(&base.instruction_list);
+
+        let combinations = 1 << eligible.iter().filter(|flag| **flag).count();
+        for mask in 0..combinations {
+            let mut branch = base.clone();
+            let mut activation = [false; 2];
+            let mut probability = 1.0;
+            let mut bit = 0;
+            for side in 0..2 {
+                if !eligible[side] {
+                    continue;
+                }
+                activation[side] = (mask & (1 << bit)) != 0;
+                probability *= if activation[side] { 0.33 } else { 0.67 };
+                bit += 1;
+            }
+            branch.update_percentage(probability);
+            add_end_of_turn_instructions(state, &mut branch, first_move_side, activation);
+            instructions.push(branch);
+        }
+    }
+}
