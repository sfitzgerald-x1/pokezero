+fn contact_status_is_valid(
+    state: &State,
+    target_side_ref: &SideReference,
+    status: &PokemonStatus,
+) -> bool {
+    let target_side = state.get_side_immutable(target_side_ref);
+    let target = target_side.get_active_immutable();
+    if target.hp <= 0
+        || target.status != PokemonStatus::NONE
+        || target_side.side_conditions.safeguard > 0
+    {
+        return false;
+    }
+
+    match status {
+        PokemonStatus::BURN => {
+            !target.has_type(&PokemonType::FIRE) && target.ability != Abilities::WATERVEIL
+        }
+        PokemonStatus::POISON => {
+            !target.has_type(&PokemonType::POISON)
+                && !target.has_type(&PokemonType::STEEL)
+                && target.ability != Abilities::IMMUNITY
+        }
+        PokemonStatus::PARALYZE => target.ability != Abilities::LIMBER,
+        PokemonStatus::SLEEP => {
+            ![Abilities::INSOMNIA, Abilities::VITALSPIRIT].contains(&target.ability)
+                && !target_side.has_alive_non_rested_sleeping_pkmn()
+        }
+        _ => false,
+    }
+}
+
+pub fn update_forecast(state: &mut State, instructions: &mut StateInstructions) {
+    let weather = if state.weather_is_active(&state.weather.weather_type) {
+        state.weather.weather_type
+    } else {
+        Weather::NONE
+    };
+    let new_type = match weather {
+        Weather::SUN => PokemonType::FIRE,
+        Weather::RAIN => PokemonType::WATER,
+        Weather::HAIL => PokemonType::ICE,
+        Weather::SAND | Weather::NONE => PokemonType::NORMAL,
+    };
+
+    for side_ref in [SideReference::SideOne, SideReference::SideTwo] {
+        let mon = state.get_side(&side_ref).get_active();
+        if mon.id != PokemonName::CASTFORM || mon.ability != Abilities::FORECAST {
+            continue;
+        }
+        let new_types = (new_type, PokemonType::TYPELESS);
+        if mon.types != new_types {
+            let old_types = mon.types;
+            mon.types = new_types;
+            instructions
+                .instruction_list
+                .push(Instruction::ChangeType(ChangeType {
+                    side_ref,
+                    new_types,
+                    old_types,
+                }));
+        }
+    }
+}
