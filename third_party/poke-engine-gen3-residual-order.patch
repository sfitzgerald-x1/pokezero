+// pokezero gen3 residual-order split: Shed Skin is Showdown gen3 residual
+// order 5.3 (before status damage); Speed Boost (27) and the rain heals
+// (10.3) stay in ability_end_of_turn after status damage.
+pub fn ability_end_of_turn_order5(
+    state: &mut State,
+    side_ref: &SideReference,
+    instructions: &mut StateInstructions,
+) {
+    let (attacking_side, _defending_side) = state.get_both_sides(side_ref);
+    let active_pkmn = attacking_side.get_active();
+    match active_pkmn.ability {
+        // Shed skin only has a 1/3 chance of activating at the end of the turn
+        // but I'm not going to branch on that here
+        Abilities::SHEDSKIN => {
+            if active_pkmn.status != PokemonStatus::NONE {
+                let attacking_side = state.get_side(side_ref);
+                let active_index = attacking_side.active_index;
+                let active_pkmn = attacking_side.get_active();
+
+                add_remove_status_instructions(
+                    instructions,
+                    active_index,
+                    *side_ref,
+                    attacking_side,
+                );
+            }
+        }
+        _ => {}
+    }
+}
